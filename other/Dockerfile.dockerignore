# This file is moved to the root directory before building the image

/node_modules
*.log
.DS_Store
.env
/.cache
/public/build
/build

# generated files — copied from the build stage; don't let a local stale
# copy leak in via `ADD . .` when someone runs `docker build` by hand
/app/generated
/app/components/ui/icons

# local dev sqlite (prod db lives in LiteFS at /litefs/data)
/prisma/data.db
/prisma/data.db-journal
